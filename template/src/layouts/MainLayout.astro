---
import '@styles/global.css'
import Header from '@components/Header.astro'
import Toast from '@components/Toast.astro'
import { ClientRouter } from 'astro:transitions'
import favicon from '@assets/logo.svg?url'
import { docsConfig } from '@lib/docs/config'

const { activeBranch, hideSearch } = Astro.props as { activeBranch?: string; hideSearch?: boolean }
const base = docsConfig.basePath
const homeHref = base.endsWith('/') ? base : base + '/'
const assetPrefix = base.endsWith('/') ? base : `${base}/`
const defaultBranch = docsConfig.branches[0]?.root.split('/').pop()!
const resolvedBranch = hideSearch ? undefined : (activeBranch ?? defaultBranch)
const pagefindBundle = resolvedBranch ? `pagefind-${resolvedBranch}` : ''
const pagefindPath = pagefindBundle ? `${assetPrefix}${pagefindBundle}/` : ''
---

<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <meta
      name='viewport'
      content='width=device-width'
    />
    <link
      rel='icon'
      type='image/png'
      href={favicon}
    />
    <title>{docsConfig.title}</title>
    {
      pagefindPath && (
        <>
          <link href={`${pagefindPath}pagefind-component-ui.css`} rel="stylesheet" />
          <script src={`${pagefindPath}pagefind-component-ui.js`} type="module"></script>
        </>
      )
    }
  </head>
  <body class='min-h-screen bg-sd-bg text-sd-fg'>
    <ClientRouter />
    <Header
      hideSearch={hideSearch}
      pagefindPath={pagefindPath}
      pagefindInstance={pagefindBundle}
      assetPrefix={assetPrefix}
    />
    <main class='site-container'>
      <slot />
    </main>
    <Toast />
  </body>
</html>
