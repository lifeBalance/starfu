---
interface Props {
  bundlePath?: string
  baseUrl?: string
  instance?: string
}

const { bundlePath = '', baseUrl = '/', instance = 'default' } = Astro.props as Props
---

<div class="pagefind-search">
  <pagefind-config bundle-path={bundlePath} base-url={baseUrl} instance={instance}></pagefind-config>
  <pagefind-modal-trigger placeholder="Search" instance={instance}></pagefind-modal-trigger>
  <pagefind-modal reset-on-close instance={instance}>
    <pagefind-modal-header>
      <pagefind-input instance={instance}></pagefind-input>
    </pagefind-modal-header>
    <pagefind-modal-body>
      <pagefind-summary instance={instance}></pagefind-summary>
      <pagefind-results instance={instance}></pagefind-results>
    </pagefind-modal-body>
    <pagefind-modal-footer>
      <pagefind-keyboard-hints instance={instance}></pagefind-keyboard-hints>
    </pagefind-modal-footer>
  </pagefind-modal>
</div>

<script>
  declare global {
    interface Window {
      PagefindComponents?: {
        getInstanceManager?: () => {
          getInstanceNames?: () => string[]
          removeInstance?: (name: string) => void
        }
      }
    }
  }

  document.addEventListener('astro:before-swap', () => {
    document.querySelectorAll('pagefind-modal').forEach((modal) => {
      if ('close' in modal && typeof modal.close === 'function') {
        modal.close()
      }
    })

    const manager = window.PagefindComponents?.getInstanceManager?.()
    if (!manager?.getInstanceNames || !manager?.removeInstance) return

    for (const name of manager.getInstanceNames()) {
      manager.removeInstance(name)
    }
  })
</script>
