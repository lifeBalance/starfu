---
import { Icon } from 'astro-icon/components'
import DocsToc from './DocsToc.astro'
import TocSidebar from './sidebar/TocSidebar.astro'

interface Heading {
  depth: number
  slug: string
  text: string
}

interface NavItem { url: string; title: string }
interface NavGroup { label: string; href?: string; items: NavItem[]; header?: string }

interface Props {
  headings?: Heading[]
  nav?: NavGroup[]
  currentPath?: string
  minLevel?: number
  maxLevel?: number
}

const {
  headings = [],
  nav = [],
  currentPath = '',
  minLevel = 2,
  maxLevel = 3,
} = Astro.props as Props

const items = headings.filter(
  (heading) => heading.depth >= minLevel && heading.depth <= maxLevel
)

const hasSidebar = nav.length > 0
const hasToc = items.length > 0
---

{
  (hasSidebar || hasToc) && (
    <nav
      aria-label="Mobile docs navigation"
      class="xl:hidden sticky top-[var(--topbar-height)] z-30 -mx-6 mb-4 bg-sd-bg"
      data-docs-toc-bar
      data-sidebar-open="false"
      data-toc-open="false"
    >
      <div class="flex items-center justify-between gap-3 border-b border-sd-border bg-sd-bg px-6 py-2">
        {hasSidebar && (
          <button
            type="button"
            class="min-[1000px]:hidden inline-flex items-center gap-2 rounded-sm border border-sd-border px-3 py-1.5 text-sm font-medium text-sd-muted transition-colors hover:border-sd-accent hover:text-sd-accent cursor-pointer"
            aria-controls="docs-sidebar-drawer"
            aria-expanded="false"
            data-sidebar-toggle
          >
            <Icon name="mdi:menu" class="text-lg" />
            SIDEBAR
          </button>
        )}

        {hasToc && (
          <div class="ml-auto flex min-w-0 items-center gap-3">
            <span class="truncate text-xs font-bold uppercase tracking-wide text-sd-muted" data-docs-toc-current>
              On this page
            </span>
            <button
              type="button"
              class="inline-flex items-center gap-2 rounded-sm border border-sd-border px-3 py-1.5 text-sm font-medium text-sd-muted transition-colors hover:border-sd-accent hover:text-sd-accent cursor-pointer"
              aria-controls="docs-toc-drawer"
              aria-expanded="false"
              data-toc-toggle
            >
              <Icon name="mdi:chevron-left" class="text-lg transition-transform" data-toc-caret />
              TOC
            </button>
          </div>
        )}
      </div>

      <button
        id="docs-mobile-nav-backdrop"
        type="button"
        aria-label="Close navigation drawer"
        aria-hidden="true"
        class="fixed inset-x-0 bottom-0 top-[calc(var(--topbar-height)+3.25rem)] z-40 border-0 bg-[color-mix(in_srgb,var(--sd-bg),transparent_18%)] opacity-0 transition-opacity pointer-events-none aria-[hidden=false]:pointer-events-auto aria-[hidden=false]:opacity-100"
        data-mobile-nav-backdrop
      />

      {hasSidebar && (
        <div
          id="docs-sidebar-drawer"
          aria-hidden="true"
          inert
          class="fixed left-0 top-[calc(var(--topbar-height)+3.25rem)] z-50 h-[calc(100vh-var(--topbar-height)-3.25rem)] w-[min(82vw,22rem)] -translate-x-full overflow-y-auto border-r border-sd-border bg-sd-bg transition-transform duration-300 ease-out [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden aria-[hidden=false]:translate-x-0"
          data-sidebar-drawer
        >
          <TocSidebar {nav} heading="" {currentPath} />
        </div>
      )}

      {hasToc && (
        <div
          id="docs-toc-drawer"
          aria-hidden="true"
          inert
          class="fixed right-0 top-[calc(var(--topbar-height)+3.25rem)] z-50 h-[calc(100vh-var(--topbar-height)-3.25rem)] w-[min(82vw,22rem)] translate-x-full overflow-y-auto border-l border-sd-border bg-sd-bg p-4 transition-transform duration-300 ease-out [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden aria-[hidden=false]:translate-x-0"
          data-toc-drawer
        >
          <div class="mb-3 flex justify-between items-center gap-2">
            <h3 class="text-sm uppercase font-bold text-sd-muted">On this page</h3>
            <button
              type="button"
              aria-label="Scroll to top"
              class="inline-flex h-8 w-8 items-center justify-center rounded-sm text-sd-muted transition-colors hover:border-sd-accent hover:text-sd-accent cursor-pointer"
              data-toc-top
            >
              <Icon name="mdi:chevron-double-up" class="text-lg" />
            </button>
          </div>
          <DocsToc {headings} {minLevel} {maxLevel} showTitle={false} />
        </div>
      )}
    </nav>
  )
}

<script>
  function initDocsTocBar() {
    document.querySelectorAll<HTMLElement>('[data-docs-toc-bar]').forEach((toc) => {
      if (toc.dataset.initialized === 'true') return
      toc.dataset.initialized = 'true'

      const sidebarToggle = toc.querySelector<HTMLButtonElement>('[data-sidebar-toggle]')
      const tocToggle = toc.querySelector<HTMLButtonElement>('[data-toc-toggle]')
      const backdrop = toc.querySelector<HTMLButtonElement>('[data-mobile-nav-backdrop]')
      const sidebarDrawer = toc.querySelector<HTMLElement>('[data-sidebar-drawer]')
      const tocDrawer = toc.querySelector<HTMLElement>('[data-toc-drawer]')
      const top = toc.querySelector<HTMLButtonElement>('[data-toc-top]')
      const tocCaret = toc.querySelector<HTMLElement>('[data-toc-caret]')

      function updateBackdrop() {
        const open = toc.dataset.sidebarOpen === 'true' || toc.dataset.tocOpen === 'true'
        backdrop?.setAttribute('aria-hidden', String(!open))
      }

      function moveFocusOut(drawer: HTMLElement | null, fallback: HTMLElement | null) {
        const active = document.activeElement
        if (!(active instanceof HTMLElement) || !drawer?.contains(active)) return

        if (fallback && getComputedStyle(fallback).display !== 'none') {
          fallback.focus({ preventScroll: true })
        } else {
          active.blur()
        }
      }

      function setSidebarOpen(open: boolean) {
        if (!open) moveFocusOut(sidebarDrawer, sidebarToggle)

        toc.dataset.sidebarOpen = String(open)
        sidebarToggle?.setAttribute('aria-expanded', String(open))
        sidebarDrawer?.setAttribute('aria-hidden', String(!open))
        if (open) {
          sidebarDrawer?.removeAttribute('inert')
        } else {
          sidebarDrawer?.setAttribute('inert', '')
        }
      }

      function setTocOpen(open: boolean) {
        if (!open) moveFocusOut(tocDrawer, tocToggle)

        toc.dataset.tocOpen = String(open)
        tocToggle?.setAttribute('aria-expanded', String(open))
        tocDrawer?.setAttribute('aria-hidden', String(!open))
        if (open) {
          tocDrawer?.removeAttribute('inert')
        } else {
          tocDrawer?.setAttribute('inert', '')
        }
        tocCaret?.classList.toggle('rotate-180', open)
      }

      function closeAll() {
        setSidebarOpen(false)
        setTocOpen(false)
        updateBackdrop()
      }

      sidebarToggle?.addEventListener('click', () => {
        const open = toc.dataset.sidebarOpen !== 'true'
        setTocOpen(false)
        setSidebarOpen(open)
        updateBackdrop()
      })

      tocToggle?.addEventListener('click', () => {
        const open = toc.dataset.tocOpen !== 'true'
        setSidebarOpen(false)
        setTocOpen(open)
        updateBackdrop()
      })

      backdrop?.addEventListener('click', closeAll)

      sidebarDrawer?.querySelectorAll<HTMLAnchorElement>('a[href]').forEach((link) => {
        link.addEventListener('click', closeAll)
      })

      tocDrawer?.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((link) => {
        link.addEventListener('click', closeAll)
      })

      top?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' })
        closeAll()
      })
    })
  }

  document.addEventListener('astro:page-load', initDocsTocBar)
</script>
