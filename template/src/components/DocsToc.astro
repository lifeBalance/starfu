---
interface Props {
  headings?: Heading[]
  minLevel?: number
  maxLevel?: number
  showTitle?: boolean
}

interface Heading {
  depth: number
  slug: string
  text: string
}

const { headings = [], minLevel = 2, maxLevel = 3, showTitle = true } = Astro.props as Props

const getIndentClass = (level: number) => {
  const indents: Record<number, string> = {
    1: 'pl-0',
    2: 'pl-0',
    3: 'pl-4',
    4: 'pl-6',
    5: 'pl-8',
    6: 'pl-10',
  }
  return indents[level] ?? 'pl-0'
}

const items = headings.filter(
  (heading) => heading.depth >= minLevel && heading.depth <= maxLevel
)
---

{
  items.length > 0 && (
    <nav aria-label="On this page">
      {showTitle && <h3 class="mb-2 text-sm uppercase font-bold text-sd-muted">On this page</h3>}
      <ul class="list-none p-0 m-0">
        {items.map((heading) => (
          <li class={`${getIndentClass(heading.depth)} text-sm font-light text-sd-muted`}>
            <a
              href={`#${heading.slug}`}
              data-docs-toc-link={heading.slug}
              class="block py-1 no-underline transition-colors hover:text-sd-fg"
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<script>
  declare global {
    interface Window {
      __docsTocCleanup?: () => void
    }
  }

  function initDocsTocActiveState() {
    window.__docsTocCleanup?.()

    const links = Array.from(
      document.querySelectorAll<HTMLAnchorElement>('[data-docs-toc-link]')
    )

    if (!links.length) return

    const ids = [...new Set(
      links
        .map((link) => link.dataset.docsTocLink)
        .filter((id): id is string => !!id)
    )]

    const headings = ids
      .map((id) => document.getElementById(id))
      .filter((heading): heading is HTMLElement => !!heading)

    if (!headings.length) return

    let activeId = ''
    let ticking = false
    let disabledUntil = 0

    function activeOffset() {
      const topbar = Number.parseFloat(
        getComputedStyle(document.documentElement).getPropertyValue('--topbar-height')
      ) || 64
      const tocBar = document.querySelector<HTMLElement>('[data-docs-toc-bar]')
      const tocBarHeight = tocBar && getComputedStyle(tocBar).display !== 'none'
        ? tocBar.offsetHeight
        : 0
      return topbar + tocBarHeight + 16
    }

    function setActive(nextId: string) {
      if (nextId === activeId) return
      activeId = nextId

      const activeLink = links.find((link) => link.dataset.docsTocLink === activeId)
      const activeText = activeLink?.textContent?.trim() || 'On this page'

      document.querySelectorAll<HTMLElement>('[data-docs-toc-current]').forEach((label) => {
        label.textContent = activeText
        label.title = activeText
      })

      for (const link of links) {
        const active = link.dataset.docsTocLink === activeId
        link.classList.toggle('text-sd-accent', active)
        link.classList.toggle('font-medium', active)

        if (active) {
          link.setAttribute('aria-current', 'location')
        } else {
          link.removeAttribute('aria-current')
        }
      }
    }

    function updateActive() {
      ticking = false
      if (Date.now() < disabledUntil) return

      const offset = activeOffset()
      let nextId = ''

      for (let i = headings.length - 1; i >= 0; i--) {
        if (headings[i].getBoundingClientRect().top <= offset) {
          nextId = headings[i].id
          break
        }
      }

      setActive(nextId)
    }

    function scheduleUpdate() {
      if (ticking) return
      ticking = true
      requestAnimationFrame(updateActive)
    }

    const clickCleanups = links.map((link) => {
      const onClick = () => {
        const id = link.dataset.docsTocLink ?? ''
        disabledUntil = Date.now() + 800
        setActive(id)
        window.setTimeout(scheduleUpdate, 850)
      }
      link.addEventListener('click', onClick)
      return () => link.removeEventListener('click', onClick)
    })

    window.addEventListener('scroll', scheduleUpdate, { passive: true })
    window.addEventListener('resize', scheduleUpdate)
    scheduleUpdate()

    window.__docsTocCleanup = () => {
      window.removeEventListener('scroll', scheduleUpdate)
      window.removeEventListener('resize', scheduleUpdate)
      for (const cleanup of clickCleanups) cleanup()
      window.__docsTocCleanup = undefined
    }
  }

  document.addEventListener('astro:page-load', initDocsTocActiveState)
</script>
