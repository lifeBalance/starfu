---
interface Props {
  headings?: Heading[]
  minLevel?: number
  maxLevel?: number
  showTitle?: boolean
}

interface Heading {
  depth: number
  slug: string
  text: string
}

const { headings = [], minLevel = 2, maxLevel = 3, showTitle = true } = Astro.props as Props

const getIndentClass = (level: number) => {
  const indents: Record<number, string> = {
    1: 'pl-0',
    2: 'pl-0',
    3: 'pl-4',
    4: 'pl-6',
    5: 'pl-8',
    6: 'pl-10',
  }
  return indents[level] ?? 'pl-0'
}

const items = headings.filter(
  (heading) => heading.depth >= minLevel && heading.depth <= maxLevel
)
---

{
  items.length > 0 && (
    <nav aria-label="On this page">
      {showTitle && <h3 class="mb-2 text-sm uppercase font-bold text-sd-muted">On this page</h3>}
      <ul class="list-none p-0 m-0">
        {items.map((heading) => (
          <li class={`${getIndentClass(heading.depth)} text-sm font-light text-sd-muted`}>
            <a
              href={`#${heading.slug}`}
              class="block py-1 no-underline transition-colors hover:text-sd-fg"
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}
